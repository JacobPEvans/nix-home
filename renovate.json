{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "local>JacobPEvans/.github:renovate-presets"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Disable Renovate for packages managed by nix-update workflow (deps-update-packages.yml handles version + hash updates)",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["gittower/git-flow-next"],
      "enabled": false
    }
  ]
}
